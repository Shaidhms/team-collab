# Required: HMAC secret for signing session cookies.
# Generate one with: openssl rand -base64 48
# In Cloud Run, store this in Secret Manager and reference it.
SESSION_SECRET=

# Optional: force the in-memory store backend instead of Firestore.
# Set to "memory" for local dev without gcloud ADC, and for tests.
# Defaults to Firestore if unset.
STORE_BACKEND=

# Required for Firestore in local dev: run `gcloud auth application-default login`
# once. On Cloud Run, ADC works automatically with the runtime service account.
