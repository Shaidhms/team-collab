{
  "name": "team-collab",
  "version": "0.2.0",
  "private": true,
  "description": "A real-time shared task board for small teams. Built with Next.js 14 and deployed on Google Cloud Run.",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start -p ${PORT:-3000}",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "playwright test",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "next": "14.2.15",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@playwright/test": "^1.48.0",
    "@types/node": "^22.7.5",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitest/coverage-v8": "^2.1.2",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.15",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "vitest": "^2.1.2"
  }
}
